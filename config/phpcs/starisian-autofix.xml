<?xml version="1.0"?>
<!--
    Starisian Technologies — safe autofix ruleset (phpcbf).
    Ref: docs/php-wordpress-standard.md §8 (formatting).

    This ruleset contains ONLY rules that phpcbf can auto-fix safely without
    changing behaviour: whitespace, indentation, brace style, blank lines.
    It deliberately excludes rules that require human judgment (naming, security,
    i18n, database).

    Usage (run from consuming repo root):
        vendor/bin/phpcbf --standard=vendor/starisian-technologies/coding-standards/config/phpcs/starisian-autofix.xml src/

    After autofixing, run starisian-strict.xml to catch any remaining violations.
-->
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         name="StarisianAutofix"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">

    <description>Starisian Technologies — safe autofix ruleset for phpcbf. Formatting only.</description>

    <arg value="sp"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>

    <config name="php_version" value="80200"/>

    <!-- ── Exclusions ── -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>

    <!-- ── PSR-12 formatting rules (all fixable) ── -->
    <rule ref="PSR12.Files.FileHeader"/>
    <rule ref="PSR12.Files.OpenTag"/>
    <rule ref="Generic.Files.LineEndings">
        <properties>
            <property name="eolChar" value="\n"/>
        </properties>
    </rule>
    <rule ref="Generic.Files.ByteOrderMark"/>
    <rule ref="Generic.Formatting.SpaceAfterCast"/>
    <rule ref="Generic.Formatting.SpaceAfterNot"/>
    <rule ref="Generic.PHP.LowerCaseConstant"/>
    <rule ref="Generic.PHP.LowerCaseKeyword"/>
    <rule ref="Generic.WhiteSpace.DisallowTabIndent"/>
    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="indent" value="4"/>
            <property name="tabIndent" value="false"/>
        </properties>
    </rule>
    <rule ref="PSR2.ControlStructures.SwitchDeclaration"/>
    <rule ref="PSR2.Methods.MethodDeclaration"/>
    <rule ref="PSR2.Classes.PropertyDeclaration"/>
    <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing">
        <properties>
            <property name="equalsSpacing" value="1"/>
        </properties>
    </rule>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace"/>
    <rule ref="Squiz.WhiteSpace.OperatorSpacing"/>

    <!-- ── WordPress-style spacing (fixable) ── -->
    <rule ref="WordPress.Arrays.ArrayIndentation"/>
    <rule ref="WordPress.WhiteSpace.ControlStructureSpacing"/>
    <rule ref="WordPress.WhiteSpace.OperatorSpacing"/>

</ruleset>
